# Copy to `.env` in the project root. Never commit `.env` (gitignored).

# Firebase web app (Console → Project settings → Your apps)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Server-side Admin SDK (Console → Service accounts → Generate key)
# Required for the app to read/write Firestore (use ./ prefix, path relative to project root)
# FIREBASE_SERVICE_ACCOUNT_PATH=./your-project-firebase-adminsdk.json
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Authentication is ON when Firebase vars above are set.
# To skip login during local UI work, set:
# VITE_ALLOW_DEMO_AUTH=true

# IT staff self-signup (/signup): comma-separated allowed email domains (Microsoft 365 / work email).
# If empty, any email can register as IT staff (development only — set domains in production).
# Example: contoso.com,yourtenant.onmicrosoft.com
# VITE_ALLOWED_STAFF_EMAIL_DOMAINS=

# Optional: comma-separated domains for employee portal sign-up (/user/signup)
# VITE_ALLOWED_EMPLOYEE_EMAIL_DOMAINS=
